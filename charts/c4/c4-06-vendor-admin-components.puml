title C4 Mức 3 - Các thành phần quản lý người bán và quản trị

left to right direction

actor Người_Bán as Vendor
actor Quản_Trị_Viên as Admin

rectangle "Giao diện bảng điều khiển người bán\napp/vendor/*" as vendorui <<frontend>>
rectangle "Giao diện bảng điều khiển quản trị\napp/admin/*" as adminui <<frontend>>

rectangle "Phân hệ Quản lý" as mgmtsub <<system>> {
  rectangle "Route đơn hàng người bán\napp/api/vendor/orders/route.ts" as vendororders <<backend>>
  rectangle "Route phân tích người bán\napp/api/vendor/analytics/route.ts" as vendoranalytics <<backend>>
  rectangle "Route coupon người bán\napp/api/vendor/coupons/route.ts" as vendorcoupons <<backend>>
  rectangle "Route người dùng quản trị\napp/api/admin/users/route.ts" as adminusers <<backend>>
  rectangle "Route trạng thái người dùng (quản trị)\n.../admin/users/[id]/status/route.ts" as adminstatus <<backend>>
  rectangle "Route cửa hàng quản trị\napp/api/admin/shops/route.ts" as adminshops <<backend>>
  rectangle "Trợ giúp xác thực\nlib/api/auth-helpers.ts" as authhelpers <<security>>
  rectangle "Lớp truy vấn\nlib/db/ecommerce-queries.ts + lib/db/product-queries.ts" as queries <<backend>>
  database "Prisma + PostgreSQL" as db
}

Vendor --> vendorui : Quản lý cửa hàng, đơn hàng, mã giảm giá, xem phân tích
Admin --> adminui : Theo dõi và quản lý người dùng, cửa hàng

vendorui --> vendororders : Pipeline quản lý đơn hàng
vendorui --> vendoranalytics : Xem chỉ số doanh thu, đơn hàng, v.v
vendorui --> vendorcoupons : Quản lý mã giảm giá

adminui --> adminusers : Liệt kê và quản lý người dùng
adminui --> adminstatus : Kích hoạt hoặc vô hiệu hóa người dùng
adminui --> adminshops : Liệt kê và quản lý cửa hàng

vendororders --> authhelpers : Đảm bảo quyền người bán
vendoranalytics --> authhelpers : Đảm bảo quyền người bán
vendorcoupons --> authhelpers : Đảm bảo quyền người bán
adminusers --> authhelpers : Đảm bảo quyền người quản trị
adminstatus --> authhelpers : Đảm bảo quyền người quản trị
adminshops --> authhelpers : Đảm bảo quyền người quản trị

vendororders --> queries : Truy vấn đơn hàng
vendoranalytics --> queries : Tổng hợp dữ liệu phân tích
vendorcoupons --> queries : Truy vấn mã giảm giá
adminusers --> queries : Truy vấn người dùng
adminstatus --> queries : Cập nhật trạng thái
adminshops --> queries : Truy vấn cửa hàng
queries --> db : Lưu trữ và truy xuất dữ liệu

COMMON_LEGEND()
@enduml





