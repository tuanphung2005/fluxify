@startuml
' Theme PlantUML dùng chung cho các sơ đồ kiến trúc Fluxify.
skinparam backgroundColor #FCFCFC
skinparam defaultFontName Segoe UI
skinparam dpi 150
skinparam shadowing false
skinparam linetype ortho
skinparam ArrowColor #4B5563
skinparam ArrowThickness 1
skinparam packageStyle rectangle
skinparam classAttributeIconSize 0

skinparam rectangle {
  RoundCorner 10
  BorderColor #334155
  FontColor #0F172A
}

skinparam actor {
  BorderColor #1E293B
  FontColor #0F172A
}

skinparam database {
  BorderColor #1E293B
  FontColor #0F172A
  BackgroundColor #E2E8F0
}

skinparam note {
  BackgroundColor #FEF9C3
  BorderColor #A16207
  FontColor #78350F
}

skinparam rectangle<<system>> {
  BackgroundColor #E0F2FE
  BorderColor #0C4A6E
}

skinparam rectangle<<frontend>> {
  BackgroundColor #DCFCE7
  BorderColor #14532D
}

skinparam rectangle<<backend>> {
  BackgroundColor #DBEAFE
  BorderColor #1E3A8A
}

skinparam rectangle<<data>> {
  BackgroundColor #EDE9FE
  BorderColor #5B21B6
}

skinparam rectangle<<external>> {
  BackgroundColor #F1F5F9
  BorderColor #475569
}

skinparam rectangle<<security>> {
  BackgroundColor #FEE2E2
  BorderColor #7F1D1D
}


!definelong COMMON_LEGEND()
legend right
|= Ký hiệu |= Ý nghĩa |
|<#E0F2FE>Hệ thống|Nền tảng hoặc ranh giới hệ thống|
|<#DCFCE7>Giao diện|Giao diện người dùng hoặc component phía client|
|<#DBEAFE>Backend|API, dịch vụ, hoặc logic nghiệp vụ|
|<#E2E8F0>Dữ liệu|Cơ sở dữ liệu hoặc thành phần lưu trữ|
|<#F1F5F9>Ngoài|Tích hợp bên thứ 3 hoặc hệ thống bên ngoài|
|<#FEE2E2>Bảo mật|Xác thực, phân quyền, hoặc rào cản bảo mật|
endlegend
!enddefinelong


title C4 Mức 1 - Ngữ cảnh Hệ thống

left to right direction

actor Khách_Hàng as Customer
actor Người_Bán as Vendor
actor Quản_Trị_Viên as Admin

rectangle "Cloudinary\nLưu trữ Media" as cloudinary <<external>>
rectangle "Resend\nEmail Giao dịch" as resend <<external>>
rectangle "VietQR\nCung cấp Mã QR Thanh toán" as vietqr <<external>>

rectangle "Nền tảng Fluxify" as fluxify <<system>> {
  rectangle "Ứng dụng Web Next.js" as web <<frontend>>
  rectangle "Trình xử lý API (Bộ xử lý route)" as api <<backend>>
  database "PostgreSQL" as db
}

Customer --> web : Xem các cửa hàng\nQuản lý giỏ hàng\nĐặt đơn hàng
Vendor --> web : Quản lý sản phẩm\nXem đơn đã đặt\nXây dựng shop
Admin --> web : Quản lý user\nQuản lý shops

web --> api : Các yêu cầu HTTPS
api --> db : Đọc / viết dữ liệu
api --> cloudinary : Đăng các ảnh/video
api --> resend : Gửi mã xác nhận và hóa đơn qua email
api --> vietqr : Tạo QR chuyển khoản

COMMON_LEGEND()
@enduml





