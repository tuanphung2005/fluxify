@startuml
' Theme PlantUML dùng chung cho các sơ đồ kiến trúc Fluxify.
skinparam backgroundColor #FCFCFC
skinparam defaultFontName Segoe UI
skinparam dpi 150
skinparam shadowing false
skinparam linetype ortho
skinparam ArrowColor #4B5563
skinparam ArrowThickness 1
skinparam packageStyle rectangle
skinparam classAttributeIconSize 0

skinparam rectangle {
  RoundCorner 10
  BorderColor #334155
  FontColor #0F172A
}

skinparam actor {
  BorderColor #1E293B
  FontColor #0F172A
}

skinparam database {
  BorderColor #1E293B
  FontColor #0F172A
  BackgroundColor #E2E8F0
}

skinparam note {
  BackgroundColor #FEF9C3
  BorderColor #A16207
  FontColor #78350F
}

skinparam rectangle<<system>> {
  BackgroundColor #E0F2FE
  BorderColor #0C4A6E
}

skinparam rectangle<<frontend>> {
  BackgroundColor #DCFCE7
  BorderColor #14532D
}

skinparam rectangle<<backend>> {
  BackgroundColor #DBEAFE
  BorderColor #1E3A8A
}

skinparam rectangle<<data>> {
  BackgroundColor #EDE9FE
  BorderColor #5B21B6
}

skinparam rectangle<<external>> {
  BackgroundColor #F1F5F9
  BorderColor #475569
}

skinparam rectangle<<security>> {
  BackgroundColor #FEE2E2
  BorderColor #7F1D1D
}


title Fluxify UML - Vòng đời nháp và xuất bản mẫu cửa hàng

start

:Người bán mở trình dựng cửa hàng;
:Tải mẫu từ /api/shop/template;

if (Mẫu đã tồn tại?) then (yes)
  :Tải cây thành phần hiện có;
else (no)
  :Tạo mẫu mặc định từ cấu hình dự phòng;
endif

repeat
  :Add/edit component\n(/api/shop/components);
  :Reorder component\n(/api/shop/components/reorder);
  :Batch synchronize changes\n(/api/shop/components/sync);
repeat while (Còn chỉnh sửa?) is (yes)

:Xem trước giao diện cửa hàng;

if (Xuất bản ngay?) then (yes)
  :Lưu snapshot đã xuất bản\n(publishedComponents);
  :Cung cấp cấu hình mới nhất cho trang cửa hàng;
else (no)
  :Giữ bản nháp ở trạng thái có thể chỉnh sửa;
endif

:Trả về tóm tắt trình dựng và kết quả đồng bộ;
stop

@enduml




